{
  "openapi": "3.0.3",
  "info": {
    "title": "watsonx AI Translator",
    "description": "Multi-format document translation using IBM watsonx.ai.\n\n**Supported formats:** PDF, DOCX, XLSX, PPTX, HTML, Markdown, plain text\n\n**Language pairs:** Any to Any (Japanese, English, Portuguese, Spanish, French, German, ...)",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://watsonx-translator.2907fwm9n6us.us-south.codeengine.appdomain.cloud"
    }
  ],
  "tags": [
    {
      "name": "Info",
      "description": "Service metadata: health, models, formats, regions"
    },
    {
      "name": "Translation",
      "description": "Document and text translation endpoints"
    },
    {
      "name": "Download",
      "description": "Retrieve translated artifacts"
    }
  ],
  "paths": {
    "/api/v1/translate/text": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "Translate document text",
        "description": "Translate text extracted from a document. Returns the translated text and a download link to a PDF file uploaded to COS.",
        "operationId": "translate_document_text",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateTextRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateTextResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TranslateTextRequest": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "description": "Full text content of the document to translate."
          },
          "filename": {
            "type": "string",
            "description": "Original filename of the document, e.g. report.pdf. Used to name the output file."
          },
          "source_lang": {
            "type": "string",
            "default": "auto",
            "description": "Source language. Use 'auto' to detect. Examples: 'Japanese', 'Portuguese', 'Spanish'."
          },
          "target_lang": {
            "type": "string",
            "default": "English",
            "description": "Target language. Examples: 'English', 'Japanese', 'Spanish', 'Portuguese'."
          }
        }
      },
      "TranslateTextResponse": {
        "type": "object",
        "properties": {
          "translated_text": {
            "type": "string"
          },
          "source_lang": {
            "type": "string"
          },
          "target_lang": {
            "type": "string"
          },
          "model_used": {
            "type": "string"
          },
          "source_chars": {
            "type": "integer"
          },
          "translated_chars": {
            "type": "integer"
          },
          "download_url": {
            "type": "string",
            "description": "COS URL of the translated PDF file."
          }
        }
      }
    }
  }
}