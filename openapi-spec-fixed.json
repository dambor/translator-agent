    "/api/v1/translate/document": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "Translate any document (PDF, Word, Excel, PowerPoint, ...)",
        "description": "Upload a document in any supported format. The agent extracts text, translates it using the selected watsonx.ai model, and returns the translated file in the **same format** as the input (DOCX to DOCX, XLSX to XLSX, PPTX to PPTX, PDF to PDF).\n\nSet `source_lang='auto'` for automatic language detection.\n\n**Examples:** Japanese to English, English to Japanese, Portuguese to Spanish, French to German, ...",
        "operationId": "translate_document",
        "parameters": [
          {
            "name": "source_lang",
            "in": "query",
            "required": false,
            "description": "Source language (e.g. 'Japanese', 'Portuguese'). Use 'auto' to detect automatically.",
            "schema": {
              "type": "string",
              "default": "auto"
            }
          },
          {
            "name": "target_lang",
            "in": "query",
            "required": false,
            "description": "Target language (e.g. 'English', 'Spanish', 'French', 'Japanese')",
            "schema": {
              "type": "string",
              "default": "English"
            }
          },
          {
            "name": "model_id",
            "in": "query",
            "required": false,
            "description": "watsonx.ai model ID",
            "schema": {
              "type": "string",
              "default": "ibm/granite-3-8b-instruct"
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "description": "watsonx.ai region URL",
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "project_id",
            "in": "query",
            "required": false,
            "description": "watsonx project ID",
            "schema": {
              "type": "string",
              "nullable": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_translate_document"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/translate/pdf": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "Translate a PDF document",
        "description": "Upload a PDF. Extracts text (using docling with pypdf fallback), translates each page, and returns a downloadable translated PDF.\n\nNow supports any language pair, not just Japanese to English.",
        "operationId": "translate_pdf",
        "parameters": [
          {
            "name": "source_lang",
            "in": "query",
            "required": false,
            "description": "Source language",
            "schema": {
              "type": "string",
              "default": "Japanese"
            }
          },
          {
            "name": "target_lang",
            "in": "query",
            "required": false,
            "description": "Target language",
            "schema": {
              "type": "string",
              "default": "English"
            }
          },
          {
            "name": "model_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "ibm/granite-3-8b-instruct"
            }
          },
          {
            "name": "region",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          },
          {
            "name": "project_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_translate_pdf"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/translate/document-base64": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "Translate any document, base64 JSON body (for AI orchestration)",
        "description": "**Designed for AI orchestration platforms such as watsonx Orchestrate.**\n\nThe end user simply attaches a file in the chat. The orchestration platform automatically base64-encodes the attachment and calls this skill, so the user never deals with base64 themselves.\n\nSupported formats: **PDF, DOCX, XLSX, PPTX, HTML, Markdown, TXT**\n\nDOCX to DOCX, XLSX to XLSX, PPTX to PPTX (format preserved). PDF/HTML/MD/TXT to PDF.\n\nSet `source_lang='auto'` for automatic language detection.\n\n**Example payload:**\n```json\n{\n  \"file\": \"<base64-encoded content>\",\n  \"filename\": \"report.docx\",\n  \"source_lang\": \"Portuguese\",\n  \"target_lang\": \"Japanese\"\n}\n```",
        "operationId": "translate_document_base64",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateDocumentBase64Request"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/translate/pdf-base64": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "[Deprecated] Use /api/v1/translate/document-base64 instead",
        "description": "Backward-compatible alias. Use `/api/v1/translate/document-base64` for new integrations.",
        "operationId": "translate_pdf_base64",
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateDocumentBase64Request"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/translate/from-source": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "Translate a document from a file path, URL, or bucket",
        "description": "Fetch a document from a server path, HTTP URL, or S3-compatible bucket and translate it.",
        "operationId": "translate_from_source",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateFromSourceRequest"
