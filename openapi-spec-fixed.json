{
  "openapi": "3.0.3",
  "info": {
    "title": "watsonx AI Translator",
    "description": "Multi-format document translation using IBM watsonx.ai.\n\n**Supported formats:** PDF, DOCX, XLSX, PPTX, HTML, Markdown, plain text\n\n**Language pairs:** Any to Any (Japanese, English, Portuguese, Spanish, French, German, ...)",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://watsonx-translator.2907fwm9n6us.us-south.codeengine.appdomain.cloud"
    }
  ],
  "tags": [
    {
      "name": "Info",
      "description": "Service metadata: health, models, formats, regions"
    },
    {
      "name": "Translation",
      "description": "Document and text translation endpoints"
    },
    {
      "name": "Download",
      "description": "Retrieve translated artifacts"
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "Info"
        ],
        "summary": "Health Check",
        "operationId": "health_check",
