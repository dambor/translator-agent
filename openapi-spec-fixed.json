{
  "openapi": "3.0.3",
  "info": {
    "title": "watsonx AI Translator",
    "description": "Multi-format document translation using IBM watsonx.ai.\n\n**Supported formats:** PDF, DOCX, XLSX, PPTX, HTML, Markdown, plain text\n\n**Language pairs:** Any to Any (Japanese, English, Portuguese, Spanish, French, German, ...)",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://watsonx-translator.2907fwm9n6us.us-south.codeengine.appdomain.cloud"
    }
  ],
  "tags": [
    {
      "name": "Info",
      "description": "Service metadata: health, models, formats, regions"
    },
    {
      "name": "Translation",
      "description": "Document and text translation endpoints"
    },
    {
      "name": "Download",
      "description": "Retrieve translated artifacts"
    }
  ],
  "paths": {
    "/api/v1/translate/document": {
      "post": {
        "tags": [
          "Translation"
        ],
        "summary": "Translate any document (PDF, Word, Excel, PowerPoint, ...)",
        "description": "Upload a document in any supported format. The agent extracts text, translates it using the selected watsonx.ai model, and returns the translated file in the **same format** as the input (DOCX to DOCX, XLSX to XLSX, PPTX to PPTX, PDF to PDF).\n\nSet `source_lang='auto'` for automatic language detection.\n\n**Examples:** Japanese to English, English to Japanese, Portuguese to Spanish, French to German, ...",
        "operationId": "translate_document",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_translate_document"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_translate_document": {
        "type": "object",
        "required": [
          "file"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Document to translate. Supported formats: PDF, DOCX, XLSX, PPTX, HTML, Markdown, TXT."
          },
          "source_lang": {
            "type": "string",
            "default": "auto",
            "description": "Language of the source document. Examples: 'Japanese', 'Portuguese', 'Spanish', 'French'. Use 'auto' to detect automatically."
          },
          "target_lang": {
            "type": "string",
            "default": "English",
            "description": "Language to translate into. Examples: 'English', 'Japanese', 'Spanish', 'French', 'Portuguese'."
          }
        }
      },
      "TranslateResponse": {
        "type": "object",
        "required": [
          "message",
          "source_lang",
          "target_lang",
          "pages_translated",
          "model_used",
          "region",
          "download_url",
          "pages"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "source_lang": {
            "type": "string"
          },
          "target_lang": {
            "type": "string"
          },
          "pages_translated": {
            "type": "integer"
          },
          "model_used": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "download_url": {
            "type": "string"
          },
          "pages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "page": {
                  "type": "integer"
                },
                "source_chars": {
                  "type": "integer"
                },
                "translated_chars": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "properties": {
          "loc": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            }
          },
          "msg": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "input": {
            "type": "string",
            "nullable": true,
            "description": "The input value that caused the validation error"
          },
          "ctx": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      }
    }
  }
}