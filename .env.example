# ── watsonx AI Translator Agent Configuration ───────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit this file to version control.

# Required
IBM_CLOUD_API_KEY=your-ibm-cloud-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id

# Optional: Override defaults
APP_URL=http://localhost:8000
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_API_VERSION=2024-05-01
CHUNK_SIZE=3000

# Optional: Upload translated PDFs to IBM COS (recommended for Code Engine deployments)
# When set, download_url in the response points directly to the COS object URL.
OUTPUT_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
OUTPUT_COS_BUCKET=prudential-langflow
OUTPUT_COS_ACCESS_KEY=your-hmac-access-key
OUTPUT_COS_SECRET_KEY=your-hmac-secret-key